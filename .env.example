# ---- LLM (OpenAI-compatible relay) ----
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.zhizengzeng.com/v1/
LLM_MODEL=gpt-4o-mini

# ---- Feishu (optional; only needed for BitableBackend) ----
# 从飞书开放平台-自建应用 获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 目标多维表格的 app_token（从 URL 中复制）
FEISHU_BITABLE_APP_TOKEN=
# OAuth 本地回调端口，默认 18080，一般不用改
FEISHU_OAUTH_PORT=18080
